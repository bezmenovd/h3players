{
  "name": "h3players",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "type": "commonjs",
  "scripts": {
    "api:build": "tsc -p src/api/tsconfig.build.json",
    "api:start": "cd src/api && nest start",
    "api:start:dev": "cd src/api && nest start --watch",
    "api:start:debug": "cd src/api && nest start src/api --debug --watch",
    "api:start:prod": "node dist/api/main.js",
    "web:dev": "cd src/web && vite build --watch",
    "web:build": "cd src/web && vite build",
    "convert": "tsx src/workers/convert.ts",
    "test": "tsx src/workers/test.ts",
    "workers:spectator:dev": "tsx src/workers/spectator.ts",
    "workers:spectator:build": "tsup --config src/workers/spectator.tsup.config.ts --clean",
    "workers:spectator": "node dist/workers/spectator/spectator.js",
    "workers:journalist:dev": "tsx src/workers/journalist.ts",
    "workers:journalist:build": "tsup --config src/workers/journalist.tsup.config.ts --clean",
    "workers:journalist": "node dist/workers/journalist/journalist.js",
    "workers:archivist:dev": "tsx src/workers/archivist.ts",
    "workers:archivist:build": "tsup --config src/workers/archivist.tsup.config.ts --clean",
    "workers:archivist": "node dist/workers/archivist/archivist.js",
    "workers:coordinator:dev": "tsx src/workers/coordinator.ts",
    "workers:coordinator:build": "tsup --config src/workers/coordinator.tsup.config.ts --clean",
    "workers:coordinator": "node dist/workers/coordinator/coordinator.js",
    "workers:processor:dev": "tsx src/workers/processor.ts",
    "workers:processor:build": "tsup --config src/workers/processor.tsup.config.ts --clean",
    "workers:processor": "node dist/workers/processor/processor.js",
    "workers:background:dev": "tsx src/workers/background.ts",
    "workers:background:build": "tsup --config src/workers/background.tsup.config.ts --clean",
    "workers:background": "node dist/workers/background/background.js",
    "wss": "node dist/wss/server.js",
    "wss:dev": "tsx src/wss/server.ts",
    "wss:build": "tsup --config src/wss/tsup.config.ts --clean",
    "workers:build": "yarn workers:spectator:build && yarn workers:journalist:build && yarn workers:archivist:build && yarn workers:coordinator:build && yarn workers:processor:build"
  },
  "dependencies": {
    "@clickhouse/client": "^1.12.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "axios": "^1.13.1",
    "debounce": "^3.0.0",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.3",
    "pino-pretty": "^13.1.2",
    "pino-roll": "^4.0.0",
    "pm2": "^6.0.13",
    "redis": "^5.9.0",
    "reflect-metadata": "^0.2.2",
    "rotating-file-stream": "^3.2.7",
    "rxjs": "^7.8.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "vite": "^7.1.12",
    "vue": "3",
    "vue-i18n": "^11.1.12",
    "vue-router": "^4.6.3",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/nprogress": "^0.2.3",
    "@types/supertest": "^6.0.2",
    "globals": "^16.0.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
